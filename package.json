{
  "name": "@egose/n8n-toolkit",
  "version": "0.1.0",
  "description": "A toolkit for n8n, providing a TypeScript client for the n8n API and utilities for workflow automation.",
  "scripts": {
    "lint-fix": "eslint --fix .",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present --workspace-concurrency=1 test",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.tests.json",
    "release": "release-it",
    "changelog": "repo-toolkit-changelog",
    "publish-packages": "repo-toolkit-publish-packages"
  },
  "type": "module",
  "keywords": [],
  "author": "Junmin Ahn",
  "license": "Apache-2.0",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/egose/n8n-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/egose/n8n-toolkit/issues"
  },
  "homepage": "https://n8n-toolkit.pages.dev/",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/format": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@release-it/bumper": "^7.0.5",
    "@repo-toolkit/changelog": "^0.7.2",
    "@repo-toolkit/publish-packages": "^0.7.2",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/node": "^25.5.0",
    "dotenv": "^17.4.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "4.0.0-alpha.13",
    "release-it": "^20.0.1",
    "rimraf": "^6.1.3",
    "semver": "^7.7.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4",
    "yargs": "^18.0.0"
  }
}
