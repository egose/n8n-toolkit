## Copy this file to .env before running docker compose.

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=n8n

# n8n instance-level secrets (must match on both n8n services so credential
# blobs encrypted on the publisher can be decrypted on the subscriber).
N8N_ENCRYPTION_KEY=super-secret-key
N8N_USER_MANAGEMENT_JWT_SECRET=even-more-secret
N8N_BASE_URL=http://localhost:5678

# Host ports for the two n8n instances.
N8N1_PORT=5678
N8N2_PORT=5679
POSTGRES_PORT=5433

# @egose/n8n-sync — shared between publisher (n8n1) and subscriber (n8n2).
SYNC_SHARED_SECRET=sync-shared-secret
SYNC_AUTH_MODE=hmac

# Provisioner: owner account it will create on each n8n instance.
OWNER_EMAIL=owner@example.com
OWNER_FIRST_NAME=Owner
OWNER_LAST_NAME=User
OWNER_PASSWORD=OwnerPassword123!
API_KEY_LABEL=integration-tests
